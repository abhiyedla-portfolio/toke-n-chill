NEXTJS_ENV=development
NEXT_PUBLIC_BRAND=toke-and-chill
CLOVER_API_BASE_URL=https://api.clover.com/v3
CLOVER_CACHE_TTL=300
CLOVER_SYNC_SECRET=replace-me
CLOVER_MERCHANT_ID_TOKE=
CLOVER_API_TOKEN_TOKE=
CLOVER_MERCHANT_ID_DIZZY=
CLOVER_API_TOKEN_DIZZY=

# ── Admin Dashboard Auth ─────────────────────────────────────
# Used by /admin login. Set strong values in production.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# Generate with: openssl rand -hex 32
ADMIN_JWT_SECRET=

# ── Operations Automation ────────────────────────────────────

# Clover webhook signature verification secret (from Clover Developer Dashboard)
# Leave blank to skip verification during development
CLOVER_WEBHOOK_SECRET=

# ── WhatsApp Group Alerts via Baileys service ────────────────────────
# The Baileys service is a separate Node.js app (see baileys-service/).
# It maintains a persistent WhatsApp session and forwards messages to your group.
#
# WHATSAPP_SERVICE_URL    — URL where the Baileys service is running
#                           Local:      http://localhost:3001
#                           Deployed:   https://your-app.railway.app
# WHATSAPP_SERVICE_SECRET — must match SERVICE_SECRET in baileys-service/.env
WHATSAPP_SERVICE_URL=http://localhost:3001
WHATSAPP_SERVICE_SECRET=change-me-to-something-secure

# ── Telegram Bot Alerts (optional — fires alongside WhatsApp) ────────
# 1. Message @BotFather on Telegram → /newbot → copy the token below
# 2. Start a chat with your new bot, then open:
#    https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#    to find your chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Discord Webhook Alerts (optional — fires alongside WhatsApp) ─────
# Create a webhook: Discord channel → Edit Channel → Integrations → Webhooks
DISCORD_WEBHOOK_URL=

# Fraud detection thresholds
# Individual refund/void alert threshold in cents (default: $20.00 = 2000)
FRAUD_REFUND_THRESHOLD_CENTS=2000
# How many refunds/voids in a 1-hour window before a "multiple refunds" alert fires
FRAUD_MULTIPLE_REFUND_COUNT=3
# Minutes after scheduled close before an order is flagged as after-hours (default: 15)
FRAUD_AFTER_HOURS_BUFFER_MINUTES=15

# Grace periods in minutes before an alert fires
OPEN_GRACE_MINUTES=30
CLOSE_GRACE_MINUTES=30
LATE_CLOCK_IN_MINUTES=20
